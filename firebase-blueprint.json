{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "settings": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["dark", "light", "system"] },
            "accentColor": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Chat": {
      "title": "Chat Thread",
      "description": "A conversation thread between the user and AI",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "userId", "title", "createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "An individual message in a chat",
      "type": "object",
      "properties": {
        "messageId": { "type": "string" },
        "chatId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["messageId", "chatId", "role", "content", "createdAt"]
    },
    "OTP": {
      "title": "One-Time Password",
      "description": "Temporary code for authentication",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "code": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Stores chat metadata"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Stores all messages within a specific chat"
    },
    "/otps/{id}": {
      "schema": "OTP",
      "description": "System-only: temporary authentication codes"
    }
  }
}
